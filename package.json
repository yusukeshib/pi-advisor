{
  "name": "pi-advisor",
  "version": "0.3.0",
  "description": "Pi extension package that adds a Claude-style advisor tool for strategic guidance during complex agent tasks.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RimuruW/pi-advisor.git"
  },
  "homepage": "https://github.com/RimuruW/pi-advisor",
  "bugs": {
    "url": "https://github.com/RimuruW/pi-advisor/issues"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "advisor",
    "coding-agent"
  ],
  "license": "MIT",
  "files": [
    "index.ts",
    "src/",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm test"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.79.1",
    "@earendil-works/pi-coding-agent": "^0.79.1",
    "@earendil-works/pi-tui": "^0.79.1",
    "@types/node": "^25.9.3",
    "typebox": "^1.2.8",
    "typescript": "^6.0.3"
  }
}
